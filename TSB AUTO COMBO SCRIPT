image.Position = UDim2.new(0,0,0,0)
image.BackgroundTransparency = 1
image.Image = IMAGE_ID
image.Parent = gui

-- SOUND
local sound = Instance.new("Sound")
sound.SoundId = SOUND_ID
sound.Volume = 10
sound.Looped = true
sound.Parent = gui

-- INSTANT SHOW
image.Visible = true
sound:Play()
